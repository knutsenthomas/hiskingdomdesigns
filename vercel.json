{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).(webp|png|jpg|jpeg|gif|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/_api/:path*",
      "destination": "https://thomas7558.wixstudio.com/his-kingdom-minist-1/_api/:path*"
    },
    {
      "source": "/:lang(en|es)/_api/:path*",
      "destination": "https://thomas7558.wixstudio.com/his-kingdom-minist-1/:lang/_api/:path*"
    },
    {
      "source": "/__ecom/:path*",
      "destination": "https://thomas7558.wixstudio.com/his-kingdom-minist-1/__ecom/:path*"
    },
    {
      "source": "/:lang(en|es)/__ecom/:path*",
      "destination": "https://thomas7558.wixstudio.com/his-kingdom-minist-1/:lang/__ecom/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
